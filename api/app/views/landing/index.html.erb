<%# Hero %>
<section class="hero">
  <div class="container">
    <p class="section-label">Plataforma SaaS</p>
    <h1 class="hero-title">
      Tu local, <span>online</span><br>en minutos.
    </h1>
    <p class="hero-subtitle">
      Two Brothers es la plataforma completa para que pollerías y comercios
      gastronómicos gestionen pedidos online, delivery y su menú digital
      desde un solo lugar.
    </p>
    <a href="#como-funciona" class="hero-cta">Cómo funciona →</a>
  </div>
</section>

<%# Features %>
<section class="features-bg">
  <div class="container">
    <p class="section-label">Lo que incluye</p>
    <h2 style="font-size: 1.6rem; font-weight: 700; letter-spacing: -0.5px;">
      Todo lo que necesitás para vender online
    </h2>

    <div class="features-grid">
      <div class="feature-card">
        <span class="feature-icon">🛒</span>
        <p class="feature-title">Pedidos online</p>
        <p class="feature-desc">Tus clientes eligen del menú, completan su pedido y lo recibís en tiempo real en el panel de administración.</p>
      </div>

      <div class="feature-card">
        <span class="feature-icon">📍</span>
        <p class="feature-title">Seguimiento de delivery</p>
        <p class="feature-desc">El cliente ve en un mapa la ubicación del repartidor en tiempo real hasta que llega a su puerta.</p>
      </div>

      <div class="feature-card">
        <span class="feature-icon">🍗</span>
        <p class="feature-title">Menú digital</p>
        <p class="feature-desc">Cargá y actualizá tu menú con fotos, categorías y precios desde el panel. Sin depender de terceros.</p>
      </div>

      <div class="feature-card">
        <span class="feature-icon">📊</span>
        <p class="feature-title">Panel de administración</p>
        <p class="feature-desc">Dashboard con el resumen del día, historial de órdenes, gestión de stock y reportes de ventas.</p>
      </div>
    </div>
  </div>
</section>

<%# How it works %>
<section id="como-funciona">
  <div class="container">
    <p class="section-label">El proceso</p>
    <h2 style="font-size: 1.6rem; font-weight: 700; letter-spacing: -0.5px;">
      De cero a online en tres pasos
    </h2>

    <div class="steps">
      <div class="step">
        <div class="step-number">1</div>
        <p class="step-title">Nos contactás</p>
        <p class="step-desc">Escribinos a hola@two-brothers.shop y coordinamos una llamada para conocer tu local.</p>
      </div>

      <div class="step">
        <div class="step-number">2</div>
        <p class="step-title">Configuramos tu local</p>
        <p class="step-desc">Creamos tu espacio en la plataforma, cargamos el menú y ajustamos los horarios de atención.</p>
      </div>

      <div class="step">
        <div class="step-number">3</div>
        <p class="step-title">Empezás a recibir pedidos</p>
        <p class="step-desc">Compartís el link a tus clientes y comenzás a gestionar pedidos desde el panel.</p>
      </div>
    </div>
  </div>
</section>
