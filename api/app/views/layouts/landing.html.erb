      }
      .bg-primary-gradient {
        background: linear-gradient(135deg, #61e698 0%, #40c97f 100%);
      }
      .editorial-grid {
        display: grid;
        grid-template-columns: repeat(12, 1fr);
      }
    </style>
</head>
<body class="bg-background text-on-background font-body selection:bg-primary selection:text-on-primary">
<!-- Top Navigation Shell -->
<nav class="fixed top-0 w-full z-50 bg-[#111318]/70 backdrop-blur-xl flex justify-between items-center px-6 md:px-12 py-6 max-w-full mx-auto">
<div class="text-2xl font-bold tracking-tighter text-[#e2e2e9] font-headline">Two Brothers</div>
<div class="hidden md:flex items-center gap-10">
<a class="text-[#61e698] border-b-2 border-[#61e698] pb-1 font-semibold tracking-tight font-headline" href="#">Plataforma</a>
<a class="text-[#bccabd] hover:text-[#61e698] transition-colors duration-400 ease-in-out font-semibold tracking-tight font-headline" href="#">Soluciones</a>
