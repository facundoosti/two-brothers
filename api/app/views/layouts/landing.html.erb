<li><a class="hover:text-white transition-opacity duration-300" href="#">Nosotros</a></li>
<li><a class="hover:text-white transition-opacity duration-300" href="#">Casos de Éxito</a></li>
<li><a class="hover:text-white transition-opacity duration-300" href="#">Blog</a></li>
<li><a class="hover:text-white transition-opacity duration-300" href="#">Legal</a></li>
</ul>
