<a href="mailto:hola@two-brothers.shop" class="bg-primary-gradient text-on-primary px-8 py-3 rounded-full font-bold text-sm tracking-tight scale-95 duration-200 hover:scale-100 shadow-[0_20px_40px_rgba(97,230,152,0.15)]">
