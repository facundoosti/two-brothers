<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Two Brothers · Superadmin</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background: #0d0f14;
      color: #e8eaf0;
      min-height: 100vh;
    }

    a { color: #40c97f; text-decoration: none; }
    a:hover { text-decoration: underline; }

    .topbar {
      background: #101319;
      border-bottom: 1px solid #252a35;
      padding: 0 24px;
      height: 56px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .topbar-brand {
      font-size: 15px;
      font-weight: 700;
      color: #e8eaf0;
      letter-spacing: -0.3px;
    }

    .topbar-brand span {
      color: #40c97f;
    }

    .topbar-badge {
      font-size: 11px;
      font-weight: 600;
      background: #1e2130;
      color: #7a8099;
      border: 1px solid #252a35;
      border-radius: 4px;
      padding: 2px 8px;
    }

    .container {
      max-width: 900px;
      margin: 0 auto;
      padding: 32px 24px;
    }

    .page-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 28px;
    }

    .page-title {
      font-size: 20px;
      font-weight: 700;
      color: #e8eaf0;
    }

    .page-subtitle {
      font-size: 13px;
      color: #7a8099;
      margin-top: 2px;
    }

    .btn {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 8px 16px;
      border-radius: 8px;
      font-size: 13px;
      font-weight: 600;
      cursor: pointer;
      border: none;
      transition: opacity 0.15s;
    }

    .btn:hover { opacity: 0.85; }
    .btn:disabled { opacity: 0.5; cursor: not-allowed; }

    .btn-primary { background: #40c97f; color: #0d0f14; }
    .btn-danger  { background: #e05252; color: #fff; }
    .btn-ghost   {
      background: transparent;
      color: #7a8099;
      border: 1px solid #252a35;
    }

    .card {
      background: #151820;
      border: 1px solid #252a35;
      border-radius: 12px;
      overflow: hidden;
    }

    table {
      width: 100%;
      border-collapse: collapse;
    }

    thead th {
      text-align: left;
      font-size: 11px;
      font-weight: 600;
      color: #7a8099;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      padding: 12px 20px;
      border-bottom: 1px solid #252a35;
    }

    tbody tr { border-bottom: 1px solid #1e2130; }
    tbody tr:last-child { border-bottom: none; }
    tbody tr:hover { background: #1a1f2e; }

    tbody td {
      padding: 14px 20px;
      font-size: 14px;
      color: #e8eaf0;
    }

    .badge {
      display: inline-block;
      font-size: 11px;
      font-weight: 600;
      padding: 2px 8px;
      border-radius: 4px;
    }

    .badge-active   { background: #0f2e1d; color: #40c97f; }
    .badge-inactive { background: #2a1e1e; color: #e05252; }

    .badge-plan-penetracion { background: #1a1e2e; color: #7a9cf5; }
    .badge-plan-puente      { background: #2e2100; color: #f5a623; }
    .badge-plan-adopcion    { background: #1a2e1a; color: #40c97f; }

    .subdomain {
      font-family: "JetBrains Mono", "SF Mono", monospace;
      font-size: 13px;
      color: #a8b0c8;
    }

    .actions { display: flex; gap: 8px; align-items: center; }

    .form-group { margin-bottom: 20px; }

    label {
      display: block;
      font-size: 12px;
      font-weight: 600;
      color: #7a8099;
      text-transform: uppercase;
      letter-spacing: 0.4px;
      margin-bottom: 6px;
    }

    input[type="text"] {
      width: 100%;
      background: #1e2130;
      border: 1px solid #252a35;
      border-radius: 8px;
      padding: 10px 14px;
      font-size: 14px;
      color: #e8eaf0;
      outline: none;
      transition: border-color 0.15s;
    }

    input[type="text"]:focus { border-color: #40c97f; }

    .hint {
      font-size: 12px;
      color: #7a8099;
      margin-top: 4px;
    }

    .error-list {
      background: #2a1e1e;
      border: 1px solid #e05252;
      border-radius: 8px;
      padding: 12px 16px;
      margin-bottom: 20px;
    }

    .error-list li {
      font-size: 13px;
      color: #e87878;
      margin-left: 16px;
    }

    .flash-notice {
      background: #0f2e1d;
      border: 1px solid #40c97f;
      border-radius: 8px;
      padding: 12px 16px;
      font-size: 13px;
      color: #40c97f;
      margin-bottom: 20px;
    }

    .flash-alert {
      background: #2a1e1e;
      border: 1px solid #e05252;
      border-radius: 8px;
      padding: 12px 16px;
      font-size: 13px;
      color: #e87878;
      margin-bottom: 20px;
    }

    .empty-state {
      text-align: center;
      padding: 48px 24px;
      color: #7a8099;
    }

    .empty-state p { font-size: 14px; margin-top: 8px; }

    .nav {
      background: #101319;
      border-bottom: 1px solid #252a35;
      padding: 0 24px;
      display: flex;
      gap: 4px;
    }
    .nav-link {
      display: inline-block;
      padding: 10px 14px;
      font-size: 13px;
      font-weight: 500;
      color: #7a8099;
      text-decoration: none;
      border-bottom: 2px solid transparent;
      transition: color 0.15s, border-color 0.15s;
    }
    .nav-link:hover { color: #e8eaf0; text-decoration: none; }
    .nav-link.active { color: #40c97f; border-bottom-color: #40c97f; }

    .form-card {
      background: #151820;
      border: 1px solid #252a35;
      border-radius: 12px;
      padding: 28px;
      max-width: 480px;
    }

    .form-actions {
      display: flex;
      gap: 12px;
      margin-top: 28px;
    }
  </style>
</head>
<body>
  <div class="topbar">
    <span class="topbar-brand">
      Two Brothers <span>·</span> <%= link_to "Superadmin", superadmin_tenants_path, style: "color: #40c97f" %>
    </span>
    <span class="topbar-badge">admin.two-brothers.shop</span>
  </div>

  <nav class="nav">
    <%= link_to "Empresas",      superadmin_tenants_path,        class: "nav-link #{controller_name == 'tenants'      ? 'active' : ''}" %>
    <%= link_to "Suscripciones", superadmin_subscriptions_path,  class: "nav-link #{controller_name == 'subscriptions' ? 'active' : ''}" %>
    <%= link_to "Facturación",   superadmin_billing_periods_path, class: "nav-link #{controller_name == 'billing_periods' ? 'active' : ''}" %>
    <%= link_to "Cotizaciones",  superadmin_exchange_rates_path,  class: "nav-link #{controller_name == 'exchange_rates'  ? 'active' : ''}" %>
  </nav>

  <div class="container">
    <% if flash[:notice] %>
      <div class="flash-notice"><%= flash[:notice] %></div>
    <% end %>
    <% if flash[:alert] %>
      <div class="flash-alert"><%= flash[:alert] %></div>
    <% end %>

    <%= yield %>
  </div>
</body>
</html>
